{
  "name": "desktop-pet",
  "version": "1.0.2",
  "description": "AI desktop pet - A cute kitten companion for macOS and Windows",
  "main": "main.js",
  "author": "yangr8640-eng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yangr8640-eng/desktop-pet"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "ai",
    "deepseek",
    "macos",
    "windows",
    "cat"
  ],
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "scripts": {
    "start": "electron .",
    "icon": "python3 generate_icon.py",
    "build": "electron-builder",
    "prebuild": "npm run icon",
    "postbuild": "node scripts/generate-latest-yml.js",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  },
  "build": {
    "appId": "com.desktoppet.cat",
    "productName": "DesktopPet",
    "publish": {
      "provider": "github",
      "owner": "yangr8640-eng",
      "repo": "desktop-pet"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment",
      "artifactName": "${name}-${version}-${arch}_mac.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DesktopPet",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "main.js",
      "preload.js",
      "themes.js",
      "src/**/*",
      "pet/**/*",
      "chat/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "docx": "^9.7.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "mammoth": "^1.12.0",
    "marked": "^4.3.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jest": "^30.4.2"
  }
}
